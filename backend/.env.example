# Porta do servidor (default: 3333)
PORT=3333

# Ambiente: development | test | production (default: development)
NODE_ENV=development

# URL base da API para documentação Swagger (default: http://localhost:3333)
API_URL=http://localhost:3333

# URL de conexão com o MySQL
DATABASE_URL="mysql://app:app@localhost:3306/integrador"

# Chave secreta para assinar os tokens JWT
JWT_SECRET="segredo-integrador-dev"
